# === LLM ===
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
SLICE_CACHE_TTL_S=4
# 0 = no periodic full refresh (full only on first call / memory reset)
LLM_FULL_STATE_REFRESH_EVERY=0
SLICE_RECENT_FLOWS_LIMIT=3
LLM_CALLS_LOG_FILE=network/llm_calls.jsonl


# === RYU REST ===
# Esempio locale VM/controller: http://127.0.0.1:8080
# Esempio GUI verso VM host-only: http://192.168.64.8:8080
RYU_REST_URL=http://127.0.0.1:8080
RYU_REST_PORT=8080
GUI_VM_IP=192.168.64.8

# === Experiment ===
EXPERIMENT_RUNTIME=120
NUM_SWITCHES=3
NUM_HOSTS=5
METRICS_FILE=metrics.json



# === GUI ===
REFRESH_SEC=1

# Optional explicit endpoints (override automatic composition)
# ADD_URL=http://192.168.64.8:8080/stats/flowentry/add
# DEL_URL=http://192.168.64.8:8080/stats/flowentry/delete
